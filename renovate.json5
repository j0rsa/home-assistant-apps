{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "ignorePaths": [
    "duplicati/**"
  ],

  "allowedPostUpgradeCommands": ["sed -i .*"],
  "binarySource": "global",

  "packageRules": [
    {
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "matchFileNames": ["**/Dockerfile"],
      "postUpgradeTasks": {
        "commands": [
          "sed -i 's|^version:\\s*[^\\s]*|version: {{{newValue}}}|' {{packageFileDir}}/config.yaml",
          "sed -i 's|^version:\\s*[^\\s]*|version: {{{newValue}}}|' {{packageFileDir}}/config.yml"
        ],
        "fileFilters": ["**/config.{yaml,yml}"],
        "executionMode": "update"
      }
    }
  ]
}
