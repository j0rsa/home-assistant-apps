{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "ignorePaths": [
    "duplicati/**"
  ],
  // Self-hosted: allow commands globally, e.g. allowedCommands: ["^python3 scripts/addon_version_sync\\.py sync .+$"]
  // Handlebars fills {{{packageFileDir}}} with the Dockerfile directory (addon slug).
  "packageRules": [
    {
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "matchUpdateTypes": ["minor"],
      "automerge": true
    },
    {
      "matchManagers": ["dockerfile"],
      "postUpgradeTasks": {
        "commands": ["python3 scripts/addon_version_sync.py sync {{{packageFileDir}}}"],
        "fileFilters": ["**/config.yaml"],
        "executionMode": "update"
      }
    }
  ]
}
